digraph master {
  bgcolor="transparent"
  rankdir=TB
  splines=spline
  compound=true
  nodesep=0.30
  ranksep=0.62
  fontname="Helvetica"

  node [shape=box style="filled,rounded" fontname="Helvetica" fontsize=10.5
        fontcolor="#e8ecf4" fillcolor="#161b26" color="#3a4457" penwidth=1.3
        margin="0.16,0.09" height=0.36]
  edge [fontname="Helvetica" fontsize=8.5 fontcolor="#8b95a8"
        color="#4a5568" arrowsize=0.62 penwidth=1.15]

  /* ─────────── LANE 1 · STUDENT MACHINE (offline) ─────────── */
  subgraph cluster_stu {
    label="  STUDENT MACHINE — no network, ever  "
    fontname="Helvetica" fontsize=10 fontcolor="#F97316"
    color="#4a3316" penwidth=1.6 style="rounded" bgcolor="#12100c"
    labeljust="l"

    stu   [label="Student" shape=box fillcolor="#22201a" color="#8b95a8" fontcolor="#e8ecf4"]

    edt   [label="Editor\nVS Code · JetBrains · Neovim" fillcolor="#241a0c" color="#F97316"]

    gate  [label="Workspace has\n.provenance-manifest\nsigned by course key?"
           shape=diamond fillcolor="#1c1712" color="#F97316" fontsize=9.5 height=0.9 width=1.9]

    dorm  [label="dormant\nnothing is recorded"
           fillcolor="#15171d" color="#5d677d" fontcolor="#8b95a8" style="filled,rounded,dashed"]

    sstart[label="session.start\ngenerate session keypair,\nbind it to the manifest sig"
           fillcolor="#241a0c" color="#F97316"]

    sig   [label="signal capture\nedits · pastes · saves · focus\nexternal changes · terminal · git"
           fillcolor="#241a0c" color="#F97316"]

    chain [label="hash chain\nsha256(prev ‖ JCS(entry))"
           fillcolor="#1e1830" color="#9d7bf5"]

    slog  [label="*.slog\nappend-only ndjson" shape=note fillcolor="#1e1830" color="#9d7bf5"]

    ckpt  [label="signed checkpoint\nevery 100 entries"
           fillcolor="#1e1830" color="#9d7bf5" fontsize=9.5]

    seal  [label="SEAL\nhash logs, sign manifest.json"
           fillcolor="#0e2422" color="#17bfae"]

    bundle[label="bundle .zip\nmanifest.json + .sig\n*.slog + *.slog.meta + source"
           shape=note fillcolor="#0e2422" color="#17bfae"]
  }

  /* ─────────── LANE 2 · TRANSPORT ─────────── */
  subgraph cluster_tra {
    label="  TRANSPORT  "
    fontname="Helvetica" fontsize=10 fontcolor="#17bfae"
    color="#123c38" penwidth=1.6 style="rounded" bgcolor="#0a1413"
    labeljust="l"

    gs    [label="Gradescope\nauto-extracts the zip on upload"
           shape=hexagon fillcolor="#191c22" color="#8b95a8" fontsize=9.5]

    pgate [label="provgate\nhourly · multi-class"
           fillcolor="#0e2422" color="#17bfae"]

    prune [label="prune to delta\nmetadata copied byte-for-byte,\nonly folders filtered"
           fillcolor="#0e2422" color="#17bfae" fontsize=9.5]

    upl   [label="staff upload\nstreamed · resumable ≥1GiB"
           fillcolor="#0e2422" color="#17bfae" fontsize=9.5]

    local [label="/local offline mode\nthe same analysis-core runs in the\nbrowser — no server, nothing uploaded"
           fillcolor="#0d2416" color="#3fbf62" style="filled,rounded,dashed" fontsize=9.5]
  }

  /* ─────────── LANE 3 · SERVER ─────────── */
  subgraph cluster_srv {
    label="  SERVER — apphost  "
    fontname="Helvetica" fontsize=10 fontcolor="#4b90f7"
    color="#16294a" penwidth=1.6 style="rounded" bgcolor="#0a0f18"
    labeljust="l"

    api   [label="Hono API\nOAuth · tokens · rate limit"
           fillcolor="#0d1c33" color="#4b90f7"]

    dedup [label="seen this\nblob_sha256\nbefore?"
           shape=diamond fillcolor="#12161f" color="#4b90f7" fontsize=9 height=0.85 width=1.5]

    skip  [label="skip\ncheap by design" fillcolor="#15171d" color="#5d677d"
           fontcolor="#8b95a8" style="filled,rounded,dashed"]

    queue [label="pg-boss\none job per submission"
           shape=cds fillcolor="#0d1c33" color="#4b90f7" margin="0.28,0.10"]

    pipe  [label="ingest pipeline\nparse → match → heuristics → cross"
           fillcolor="#0d1c33" color="#4b90f7"]

    strip [label="strip student source\nstore provenance-only"
           fillcolor="#241a0c" color="#F97316" fontsize=9.5]

    pg    [label="Postgres\n21 tables · no events table"
           shape=cylinder fillcolor="#0d1c33" color="#4b90f7" height=0.62]

    blob  [label="Blob store\n/home/submit/provenance · 1TB"
           shape=cylinder fillcolor="#0d1c33" color="#4b90f7" height=0.62]

    reparse[label="loadSubmissionIndex\nLRU-cached re-parse"
           fillcolor="#0d1c33" color="#4b90f7" fontsize=9.5]
  }

  /* ─────────── LANE 4 · ANALYSIS ─────────── */
  subgraph cluster_ana {
    label="  ANALYSIS — analysis-core, isomorphic  "
    fontname="Helvetica" fontsize=10 fontcolor="#3fbf62"
    color="#153c25" penwidth=1.6 style="rounded" bgcolor="#0a130d"
    labeljust="l"

    valid [label="8 validation checks\nchain · sigs · ordering · code"
           fillcolor="#0d2416" color="#3fbf62"]

    heur  [label="18 per-submission heuristics\nprocess · environment · integrity"
           fillcolor="#0d2416" color="#3fbf62"]

    cross [label="2 cross-submission heuristics\nshared paste · pattern clone"
           fillcolor="#0d2416" color="#3fbf62"]

    flags [label="ranked flags\nseverity ↓ confidence ↓ seq ↑"
           fillcolor="#0d2416" color="#3fbf62"]
  }

  /* ─────────── LANE 5 · STAFF ─────────── */
  subgraph cluster_stf {
    label="  COURSE STAFF  "
    fontname="Helvetica" fontsize=10 fontcolor="#e8559c"
    color="#4a1b35" penwidth=1.6 style="rounded" bgcolor="#150a10"
    labeljust="l"

    spa   [label="Analyzer SPA\ncohort list, ranked"
           fillcolor="#2a0f1e" color="#e8559c"]

    triage[label="worth a\nhuman?"
           shape=diamond fillcolor="#1c1218" color="#e8559c" fontsize=9 height=0.8 width=1.3]

    drill [label="drill in\noverview · timeline · replay\nvalidation · source"
           fillcolor="#2a0f1e" color="#e8559c"]

    tune  [label="tuning UI\n24 thresholds"
           fillcolor="#2a0f1e" color="#e8559c" fontsize=9.5]

    close [label="no action" fillcolor="#15171d" color="#5d677d"
           fontcolor="#8b95a8" style="filled,rounded,dashed"]

    exp   [label="evidence export\nconduct case"
           fillcolor="#2a0f1e" color="#e8559c" fontsize=9.5]
  }

  /* ─────────── EDGES ─────────── */
  stu   -> edt    [label="types"]
  edt   -> gate   [label="on open"]
  gate  -> dorm   [label="no" color="#5d677d" style=dashed]
  gate  -> sstart [label="yes" color="#F97316"]
  sstart-> sig
  sig   -> chain  [label="one entry\nper signal"]
  chain -> slog   [label="append\natomically" color="#9d7bf5"]
  slog  -> ckpt   [label="every 100" color="#9d7bf5" style=dashed]
  ckpt  -> slog   [style=dashed color="#9d7bf5" constraint=false]
  slog  -> seal   [label="on submit"]
  seal  -> bundle [color="#17bfae"]

  bundle -> gs   [label="student uploads" color="#17bfae"]
  bundle -> upl  [label="or staff uploads\nthe whole export" color="#17bfae" style=dashed]
  gs    -> pgate [label="bulk export\nwithout_evaluations" color="#17bfae"]
  pgate -> prune
  prune -> api   [label="POST /ingest:gradescope\nwrite-scoped token" color="#17bfae"]
  upl   -> api   [color="#17bfae"]

  api   -> dedup
  dedup -> skip  [label="hit" color="#5d677d" style=dashed]
  dedup -> queue [label="miss" color="#4b90f7"]
  queue -> pipe
  pipe  -> valid [label="in-memory bundle\nstill has source" color="#3fbf62" lhead=cluster_ana]
  valid -> heur
  heur  -> cross
  cross -> flags
  flags -> pg    [label="persist" color="#4b90f7"]
  pipe  -> strip [label="after all compute" color="#F97316"]
  strip -> blob  [color="#4b90f7"]

  pg    -> spa   [label="cohort, flags, stats" color="#e8559c"]
  blob  -> reparse [label="on demand" color="#4b90f7"]
  reparse -> spa [label="events, replay,\nsource tab" color="#4b90f7"]

  spa   -> triage
  triage-> close [label="no" color="#5d677d" style=dashed]
  triage-> drill [label="yes" color="#e8559c"]
  drill -> exp
  drill -> tune  [label="thresholds\nwrong" style=dashed color="#e8559c"]
  tune  -> queue [label="recompute cohort" style=dashed color="#e8559c" constraint=false]

  bundle -> local [label="bypass:\nno server at all" color="#3fbf62" style=dashed]
}
