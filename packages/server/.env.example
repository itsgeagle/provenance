# Copy this file to .env and fill in values for local development.
# These defaults match the compose.yaml dev stack (docker compose up).

NODE_ENV=development
PORT=3000

PUBLIC_BASE_URL=http://localhost:3000

# Postgres — matches compose.yaml service
DATABASE_URL=postgres://provenance:provenance@localhost:5432/provenance
DATABASE_POOL_MAX=10

# Blob storage backend: "s3" (default) or "fs" (filesystem, e.g. NFS mount).
BLOB_STORAGE_BACKEND=s3

# --- fs backend (only when BLOB_STORAGE_BACKEND=fs) ---
# Directory where provenance bundles are stored (e.g. an NFS mount).
# BLOB_STORAGE_FS_ROOT=/srv/provenance/blobs
# HMAC secret (>=32 chars) for signing /api/v1/blob download URLs.
# BLOB_URL_SIGNING_SECRET=change-me-to-a-long-random-secret-value
# Max age (seconds) of a multipart staging dir before the reaper reclaims it.
BLOB_STORAGE_FS_STAGING_TTL_SECONDS=86400

# --- s3 backend (only when BLOB_STORAGE_BACKEND=s3) ---
# MinIO (S3-compatible) — matches compose.yaml service
# Create the bucket with: docker compose exec minio mc mb local/provenance
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=provenance
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin

# Google OAuth — create credentials at https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<your-client-secret>

# Auth configuration
AUTH_ALLOWED_HOSTED_DOMAINS=["berkeley.edu"]
AUTH_SUPERADMIN_EMAILS=[]

# Required in production. Generate with: openssl rand -base64 32
# Dev fallback used when NODE_ENV != production.
AUTH_COOKIE_SIGNING_SECRET=

# Session
SESSION_COOKIE_NAME=__Host-prov_sess
SESSION_TTL_DAYS=14

# Email (leave blank in dev — invitations log to stderr instead)
SMTP_URL=
SMTP_FROM=

# Rate limiting (leave blank in dev — falls back to in-memory)
RATE_LIMIT_REDIS_URL=

# Logging
LOG_LEVEL=info

# Ingest limits
INGEST_MAX_BUNDLE_BYTES=52428800
INGEST_MAX_BATCH_BYTES=5368709120
INGEST_MAX_BATCH_FILES=10000
# Max bytes for a streamed Gradescope upload (written to a temp file, not buffered
# in memory) — disk-bound, so much larger than INGEST_MAX_BATCH_BYTES. Default 10 GiB.
INGEST_MAX_UPLOAD_BYTES=10737418240

# Roster CSV upload size limit (bytes, default 10MB)
ROSTER_CSV_MAX_BYTES=10485760

# Worker
RECOMPUTE_MAX_PARALLEL=4
BLOB_DOWNLOAD_URL_TTL_SECONDS=300

# Ingest worker concurrency: how many ingest_file jobs are processed at once
# (pg-boss batch). Each in-flight job holds ~1 DB pool connection during its
# transaction, so keep this a few below DATABASE_POOL_MAX. Raise both together
# for a large semester import (e.g. INGEST_CONCURRENCY=8 with DATABASE_POOL_MAX=16).
# Throughput is DB-write-bound for large bundles, so returns diminish past the
# point Postgres saturates (~6-8 on a single instance).
INGEST_CONCURRENCY=4
# Bundles staged concurrently while unpacking a Gradescope export (blob write +
# row insert + enqueue per bundle). Default 1 = serial. Staging is a single
# serial job, so on network/NFS-backed storage its per-bundle writes starve the
# ingest workers; raising this overlaps them. Each in-flight stage briefly holds
# a DB connection, so keep INGEST_STAGE_CONCURRENCY + INGEST_CONCURRENCY within
# DATABASE_POOL_MAX.
INGEST_STAGE_CONCURRENCY=1
# Polling interval (ms) for the ingest_file / ingest_finalize queues. Lower =
# less per-job pickup latency (pg-boss default is 2000).
INGEST_POLLING_INTERVAL_MS=500

# --- Apphost deployment (docs/deploy-apphost.md) ---
# Unix socket path to listen on instead of a TCP port (prod-only; the apphost's
# nginx proxies to this socket). Leave unset in dev — falls back to PORT.
# SOCKET_PATH=/run/sockets/app.sock
# Directory of the built analyzer SPA served same-origin as the API (the
# Dockerfile bakes this to /app/packages/server/public).
PUBLIC_DIR=./public
# Storage quota watched by the hourly storage_quota_check cron (fs backend
# only; no-ops under the s3 backend). Default 1 TiB.
STORAGE_QUOTA_BYTES=1099511627776
STORAGE_QUOTA_WARN_PCT=80
STORAGE_QUOTA_CRITICAL_PCT=90

# --- Operational notifications (docs/superpowers/specs/2026-07-10-operational-notifications-design.md) ---
# Discord (or any compatible) incoming webhook URL for warn/critical alerts. Unset disables the webhook sink.
ALERT_WEBHOOK_URL=
# Minimum severity forwarded to the webhook sink: info | warn | critical.
ALERT_WEBHOOK_MIN_SEVERITY=warn
# Webhook POST timeout in ms.
ALERT_WEBHOOK_TIMEOUT_MS=5000
# JSON array of email addresses for the SMTP alert sink (requires SMTP_URL set above). Empty disables it.
ALERT_EMAIL_RECIPIENTS=[]
# Minimum severity forwarded to the SMTP sink: info | warn | critical.
ALERT_SMTP_MIN_SEVERITY=critical
# De-duplication window (seconds) per alert kind/severity, to avoid re-notifying on every check.
ALERT_DEDUPE_WINDOW_SECONDS=300
# Short commit SHA surfaced in the app.startup notification; baked in by the Dockerfile
# build ARG, not set by hand. Do NOT add a `GIT_SHA=` line here -- an empty runtime
# value overrides the baked-in ENV and surfaces as `sha: ""`.
