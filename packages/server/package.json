{
  "name": "@provenance/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/zod-openapi": "^0.19.4",
    "hono": "^4.7.11",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.5",
    "tsx": "^4.19.4"
  }
}
