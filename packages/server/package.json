{
  "name": "@provenance/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "npm run build --workspace=@provenance/shared",
    "dev": "tsx watch --env-file=.env src/index.ts --mode=all",
    "seed": "tsx --env-file=.env scripts/seed.ts",
    "ingest:local": "tsx --env-file=.env scripts/ingest-local.ts",
    "profile:ingest": "INGEST_PROFILE=1 tsx --env-file=.env scripts/profile-ingest.ts",
    "profile:large": "INGEST_PROFILE=1 tsx --env-file=.env scripts/profile-large-bundle.ts",
    "gen:fixture": "tsx scripts/gen-large-fixture.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:perf": "ANALYZE_PERF=1 vitest run test/perf",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/zod-openapi": "^0.19.4",
    "@provenance/analyzer": "*",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "arctic": "^3.7.0",
    "argon2": "^0.31.2",
    "aws4fetch": "^1.0.20",
    "busboy": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.11",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.7",
    "oslo": "^1.2.1",
    "papaparse": "^5.5.3",
    "pg-boss": "^10.1.7",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "postgres": "^3.4.9",
    "yaml": "^2.9.0",
    "yauzl": "^3.4.0",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@testcontainers/minio": "^12.0.0",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.0.0",
    "@types/yauzl": "^3.4.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.5",
    "testcontainers": "^12.0.0",
    "tsx": "^4.19.4"
  }
}
