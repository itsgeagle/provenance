{
  "name": "provenance-recorder",
  "displayName": "CS 61A Provenance",
  "description": "Academic integrity telemetry for CS 61A assignments.",
  "version": "0.0.0",
  "private": true,
  "publisher": "berkeley-cs61a",
  "engines": {
    "vscode": "^1.93.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:.cs61a"
  ],
  "contributes": {
    "commands": []
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@provenance/log-core": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
