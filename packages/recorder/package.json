{
  "name": "provenance-recorder",
  "displayName": "Provenance Recorder",
  "description": "Academic integrity telemetry for course assignments.",
  "version": "1.1.1",
  "icon": "icon.png",
  "private": true,
  "publisher": "itsgeagle",
  "type": "module",
  "engines": {
    "vscode": "^1.94.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:.provenance-manifest",
    "workspaceContains:provenance-manifest"
  ],
  "contributes": {
    "commands": [
      {
        "command": "provenance.prepareSubmissionBundle",
        "title": "Provenance: Prepare Submission Bundle"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "node esbuild.config.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies",
    "build:integration": "tsc -p tsconfig.integration.json",
    "test:integration": "npm run build && npm run build:integration && node ./dist-integration/test/integration/runTest.js",
    "bench": "vitest run --reporter=verbose --config vitest.bench.config.ts",
    "build:prod": "node --experimental-strip-types ../../tools/embed-course-key.ts && npm run bundle && npm run package && git -C ../.. checkout packages/recorder/src/activation/course-public-key.ts"
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@provenance/log-core": "*",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.93.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.12",
    "glob": "^13.0.6",
    "mocha": "^11.7.5"
  }
}
