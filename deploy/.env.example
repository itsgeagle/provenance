# Copy this file to deploy/.env on the apphost and fill in real values:
#
#   cp deploy/.env.example deploy/.env
#   chmod 600 deploy/.env
#
# deploy/.env is read by `docker compose -f compose.apphost.yaml` (via
# env_file: .env in the `app` service, and directly by the `postgres` /
# `pgdump` services). It is gitignored — never commit the filled-in version.
# See docs/deploy-apphost.md for the full runbook.

# --- Postgres (self-hosted container, NOT the campus MariaDB offering) ---
POSTGRES_USER=provenance
POSTGRES_PASSWORD=<generate-a-long-random-password>
POSTGRES_DB=provenance
# Host-side port the container's 5432 is published on (bound to 127.0.0.1 only
# by compose.apphost.yaml). Only needed if you want to psql in from the host.
POSTGRES_PORT=5433

# Server's database connection string.
# MUST target the compose service name "postgres", NOT "localhost" or
# "127.0.0.1" -- the app container resolves "postgres" via Docker's internal
# DNS; it cannot reach the postgres container over the host's loopback.
DATABASE_URL=postgres://provenance:<same-password-as-above>@postgres:5432/provenance

# Public URL the app is served at (behind the apphost's nginx/TLS termination).
PUBLIC_BASE_URL=https://provenance.eecs.berkeley.edu

# Blob storage: filesystem backend, backed by the /home/submit/provenance NFS
# mount (bind-mounted to /data in the app container -- see compose.apphost.yaml).
BLOB_STORAGE_BACKEND=fs
# NOTE: compose.apphost.yaml's `app.environment` block pins BLOB_STORAGE_FS_ROOT
# to /data directly, overriding whatever is set here -- listed for reference/
# consistency with packages/server/.env.example, not because it's read from here.
BLOB_STORAGE_FS_ROOT=/data
# HMAC secret (>=32 chars) for signing /api/v1/blob download URLs. Generate with:
#   openssl rand -base64 32
BLOB_URL_SIGNING_SECRET=<32+ char random secret>

# Unix socket the API server listens on inside the container. Bind-mounted to
# /srv/appsockets/provenance/main on the host (see compose.apphost.yaml
# app.volumes) so the apphost's nginx can reverse-proxy to it.
# NOTE: compose.apphost.yaml's `app.environment` block pins SOCKET_PATH to
# /run/sockets/app.sock directly, overriding whatever is set here -- same as
# BLOB_STORAGE_FS_ROOT above, listed for reference only.
SOCKET_PATH=/run/sockets/app.sock

# Google OAuth -- create credentials at https://console.cloud.google.com/
GOOGLE_OAUTH_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<your-client-secret>

# JSON array of emails granted superadmin on first login.
AUTH_SUPERADMIN_EMAILS=["<you>@berkeley.edu"]
# Required in production. Generate with: openssl rand -base64 32
AUTH_COOKIE_SIGNING_SECRET=<32+ char random secret>

# --- Operational notifications ---
# Discord incoming webhook URL (see docs/deploy-apphost.md "Notifications setup").
ALERT_WEBHOOK_URL=
# JSON array of email recipients for critical alerts. Leave empty until a
# campus SMTP relay is confirmed with IT (see the runbook's coordination
# checklist) -- there's no free outbound SMTP without one.
ALERT_EMAIL_RECIPIENTS=[]

# --- pg-dump sidecar (deploy/pg-dump-sidecar.sh) ---
# healthchecks.io dead-man's-switch URL, pinged after each nightly backup.
# Leave empty until set up (see docs/deploy-apphost.md "Notifications setup").
HEALTHCHECKS_URL=
# Number of most-recent nightly dumps to retain under /data/backups.
PGDUMP_KEEP=7

# --- Build metadata ---
# Short commit SHA baked into the image at build time:
#   GIT_SHA=$(git -C .. rev-parse --short HEAD) docker compose -f compose.apphost.yaml build
# Not required in this file -- set on the build command line instead (see the
# runbook's "First deploy" / "Redeploy" sections). Listed here as a reminder
# that it is NOT a server env var to set by hand.
GIT_SHA=
